# ============================================================
# Personal Knowledge OS — .gitignore
# ============================================================

# Secrets — never commit
.env
.envrc
*.key
*.pem
config/gmail_credentials.json
config/gmail_token.json

# Personal knowledge files — private content
my_knowledge/pdfs/*
my_knowledge/obsidian/*
my_knowledge/bookmarks.html
!my_knowledge/pdfs/.gitkeep
!my_knowledge/obsidian/.gitkeep

# Vector store — large binary data
chromadb/*
!chromadb/.gitkeep

# Logs
logs/*
!logs/.gitkeep
*.log
/tmp/openclaw/

# OpenClaw runtime
.openclaw/

# Python
__pycache__/
*.py[codz]
*$py.class
*.so
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/
*.mo
*.pot
instance/
.webassets-cache
.scrapy
docs/_build/
.pybuilder/
target/
.ipynb_checkpoints
profile_default/
ipython_config.py
__pypackages__/
celerybeat-schedule
celerybeat.pid
*.rdb
*.aof
*.pid
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/
.ruff_cache/
.pypirc
.pdm-python
.pdm-build/
.pixi
.abstra/
tempCodeRunnerFile.py

# Virtual environments
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Node
node_modules/
npm-debug.log*

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.code-workspace
.spyderproject
.spyproject
.ropeprojectmy_knowledge/Person-Reid-Model/weight/ 
*.pth 
