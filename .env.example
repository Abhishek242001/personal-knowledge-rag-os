# ============================================================
# Personal Knowledge OS — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# NEVER commit .env to git — it is gitignored
# ============================================================

# ------------------------------------------------------------
# LLM — Claude API (required)
# Get from: https://console.anthropic.com/api-keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ------------------------------------------------------------
# Telegram Bot (required)
# Get from: @BotFather on Telegram → /newbot
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=1234567890:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw

# ------------------------------------------------------------
# ngrok tunnel (required for webhook mode)
# Get from: https://dashboard.ngrok.com/get-started/your-authtoken
# ------------------------------------------------------------
NGROK_AUTHTOKEN=your-ngrok-authtoken-here
NGROK_URL=https://your-tunnel.ngrok-free.app

# ------------------------------------------------------------
# Notion API (optional — for Notion ingestion)
# Get from: https://notion.so/profile/integrations → New integration
# ------------------------------------------------------------
NOTION_API_KEY=secret_your-notion-key-here
NOTION_DATABASE_ID=your-notion-database-id-here

# ------------------------------------------------------------
# Embeddings — choose ONE option below
# ------------------------------------------------------------

# Option A: OpenAI embeddings (cloud, paid)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Option B: Ollama (local, free — uncomment to use)
# Install Ollama: https://ollama.ai
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text

# ------------------------------------------------------------
# ChromaDB — local vector store
# ------------------------------------------------------------
CHROMADB_PATH=./chromadb
CHROMADB_COLLECTION=knowledge_os

# ------------------------------------------------------------
# Gmail (optional — for Gmail thread ingestion)
# Get from: https://console.cloud.google.com → Gmail API
# ------------------------------------------------------------
# GMAIL_CREDENTIALS_PATH=./config/gmail_credentials.json

# ------------------------------------------------------------
# OpenClaw Gateway
# ------------------------------------------------------------
OPENCLAW_PORT=18789
OPENCLAW_MODEL=anthropic/claude-haiku-4-5
